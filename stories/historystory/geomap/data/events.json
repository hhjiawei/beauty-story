    {
      "id": "shang-0001", "seq": 1, "year": -1600, "yearLabel": "约前1600年",
      "title": "汤始居亳", "category": "国内", "type": "proclaim",
      "actors": { "primary": "shang", "target": null, "supporters": [] },
      "routes": [],
      "outcomes": [ { "type": "proclaim", "faction": "shang", "ruler": "汤", "title": "商侯" } ],
      "summary": "汤居于亳，修德备兵，网开三面，诸侯渐归。商之兴，自此始。",
      "quote": { "text": "汤始居亳，从先王居。", "source": "《史记·殷本纪》" }
    },
    {
      "id": "shang-0002", "seq": 2, "year": -1600, "yearLabel": "约前1600年",
      "title": "葛伯不祀，汤始征", "category": "国际", "type": "conquer",
      "actors": { "primary": "shang", "target": "ge", "supporters": [] },
      "routes": [ { "faction": "shang", "from": "bo", "toCity": "gec", "toPoint": null, "waypoints": [] } ],
      "outcomes": [ { "type": "conquer", "faction": "ge", "by": "shang" } ],
      "summary": "葛伯放纵、不祭先祖，汤起兵伐之。商汤十一征，自葛始。",
      "quote": { "text": "汤始征，自葛载，十一征而无敌于天下。", "source": "《孟子·滕文公下》" }
    },
    {
      "id": "shang-0003", "seq": 3, "year": -1596, "yearLabel": "约前1596年",
      "title": "汤征韦、顾", "category": "国际", "type": "conquer",
      "actors": { "primary": "shang", "target": "wei", "supporters": [ "gu" ] },
      "routes": [
        { "faction": "shang", "from": "bo", "toCity": "weic", "toPoint": null, "waypoints": [] },
        { "faction": "shang", "from": "bo", "toCity": "guc", "toPoint": null, "waypoints": [] }
      ],
      "outcomes": [
        { "type": "conquer", "faction": "wei", "by": "shang" },
        { "type": "conquer", "faction": "gu", "by": "shang" }
      ],
      "summary": "汤次第翦除夏之羽翼，豕韦、顾国皆灭，夏桀之势日孤。",
      "quote": { "text": "韦顾既伐，昆吾夏桀。", "source": "《诗经·商颂·长发》" }
    },
    {
      "id": "shang-0004", "seq": 4, "year": -1592, "yearLabel": "约前1592年",
      "title": "鸣条之战", "category": "国际", "type": "battle",
