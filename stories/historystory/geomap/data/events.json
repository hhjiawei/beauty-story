      "actors": { "primary": "yu", "target": "zhou", "supporters": [ "rui" ] },
      "routes": [],
      "outcomes": [
        { "type": "submit", "faction": "yu", "to": "zhou" },
        { "type": "submit", "faction": "rui", "to": "zhou" }
      ],
      "summary": "虞、芮之君争田，入周见耕者让畔、行者让路，惭而让还。诸侯闻之，多归于周。",
      "quote": { "text": "虞芮之人有狱不能决，乃如周。", "source": "《史记·周本纪》" }
    },
