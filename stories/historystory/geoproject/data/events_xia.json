{
  "events": [
    {
      "id": "evt_001",
      "year": -2070,
      "title": "大禹都阳城",
      "changes": [
        {
          "city_id": "xia_yangcheng",
          "from": "夏部落",
          "to": "夏朝",
          "vassal_of": null,
          "type": "迁都"
        }
      ],
      "note": "禹受舜禅，即位为天子，都阳城。《世本》：夏禹都阳城，避商均也。《史记·夏本纪》：禹于是遂即天子位，南面朝天下，国号曰夏后。",
      "source": "《世本·居篇》《史记·夏本纪》"
    },
    {
      "id": "evt_002",
      "year": -2068,
      "title": "大禹迁都阳翟",
      "changes": [
        {
          "city_id": "xia_yangdi",
          "from": "夏部落",
          "to": "夏朝",
          "vassal_of": null,
          "type": "迁都"
        }
      ],
      "note": "禹迁都阳翟（今河南禹州），便于控制中原。《水经注》：阳翟，夏禹始封于此为夏国。",
      "source": "《水经注》《汉书·地理志》"
    },
    {
      "id": "evt_003",
      "year": -2065,
      "title": "大禹迁都平阳",
      "changes": [
        {
