      "changes": [
        {
          "city_id": "xia_sanmiao",
          "from": "三苗",
          "to": "夏朝",
          "vassal_of": null,
          "type": "占领"
        }
      ],
      "note": "禹奉舜命征讨三苗，三苗溃败南迁。《尚书·禹贡》：三苗丕叙。《墨子·非攻》：禹征有苗。",
      "source": "《尚书·禹贡》《墨子·非攻》"
    },
    {
