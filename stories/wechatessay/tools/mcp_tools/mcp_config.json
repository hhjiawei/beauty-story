{
  "mcpServers": {
    "trendradar": {
      "transport": "streamable_http",
      "url": "http://localhost:3333/mcp",
      "description": "热点趋势雷达 MCP 服务，提供热点追踪、趋势分析工具",
      "enabled": true,
      "timeout": 30000
    },
    "wenyan": {
      "enabled": true,
      "transport": "stdio",
      "command": "wenyan-mcp",
      "env": {
        "WECHAT_APP_ID": "your_app_id",
        "WECHAT_APP_SECRET": "your_app_secret"
      }
    }
  }
}
